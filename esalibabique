end

local function _K(label)
	if _D then return end
	_D=true
	local info=label or "unknown"
	_Sec.table.insert(_findings,"[Havoc] Detected: "..info)
	_Sec.table.insert(_findings,"Time: ".._Sec.tostring(os.clock()))
	_Sec.table.insert(_findings,"Thread: ".._Sec.tostring(coroutine.running()))
	local clip=_Sec.table.concat(_findings,"\n")
	task.delay(math.random(3,7),function()
		_Sec.pcall(setclipboard,".")
	end)
