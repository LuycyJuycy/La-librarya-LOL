local function _heuristicKill(gui)
	_Sec.pcall(function()
		if _knownGuis[gui] then return end
		if _guiWhitelist[gui.Name] then return end
		local desc=gui:GetDescendants()
		local tl,sb=0,0
		for _,d in _Sec.ipairs(desc) do
			if d:IsA("TextLabel") then tl=tl+1 end
			if d:IsA("ScrollingFrame") then sb=sb+1 end
		end
		if sb>=3 and tl>=50 and _nameHasSpy(gui.Name) then _destroyGui(gui) end
	end)
end

