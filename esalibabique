local function _pK(f,label)
	local ok,err=_Sec.pcall(f)
	if not ok then
		_Sec.table.insert(_findings,"pK-err ["..label.."]: ".._Sec.tostring(err))
		if _scanErr(err) then _K(label.." [err-path]") end
	end
end

local function _stackScan(err,label)
	if _scanErr(err) then
		_Sec.table.insert(_findings,"ErrPath: ".._Sec.tostring(err))
		_K(label.." [err-path]") return
	end
	for i=0,20 do
		local s,fe=_Sec.pcall(_Sec.getfenv,i)
		if s and fe and fe~=_localEnv then
			local k={}
			for key in _Sec.pairs(fe) do
				_Sec.table.insert(k,_Sec.tostring(key))
			end
			if #k>0 then
				local leak=_Sec.table.concat(k,",")
				_Sec.table.insert(_findings,"StackLeak L"..i..": "..leak)
				_K(label.." [stack-leak L"..i..": "..leak.."]")
			end
		end
	end
end

