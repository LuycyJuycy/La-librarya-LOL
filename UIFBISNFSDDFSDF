    local keyAttempts = 0
    local maxKeyAttempts = 5
    local keyResult = nil

    ValidateBtn.Activated:Connect(function()
        if keyAttempts >= maxKeyAttempts then return end
        local key = KeyInput.Text
        if key == "" then
            StatusLabel.Text = Localization:Get("PleaseEnterKey")
            StatusLabel.TextColor3 = C3(255, 80, 80)
            return
        end
        StatusLabel.Text = Localization:Get("Validating")
        StatusLabel.TextColor3 = C3(200, 200, 200)
        ValidateBtn.Text = "..."
        task.spawn(function()
            local ok, msg = Service.Verify(key)
            if ok then
                StatusLabel.Text = msg or "Key validated!"
                StatusLabel.TextColor3 = C3(80, 255, 120)
                KeyNotify("Key validated successfully!", C3(80, 255, 120), 2)
                if SaveKey and writefile then
                    pcall(function()
                        if not isfolder("INFERNO_KEYS") then makefolder("INFERNO_KEYS") end
                        writefile(KeyFileName .. ".txt", key)
                    end)
                end
                task.delay(1, function()
                    TweenService:Create(KeyCard, TweenInfo.new(0.4, Enum.EasingStyle.Quart, Enum.EasingDirection.In), {Position = UDim2.new(0.5, 0, 1.5, 0)}):Play()
                    TweenService:Create(Overlay, TweenInfo.new(0.4), {BackgroundTransparency = 1}):Play()
                    task.delay(0.5, function()
                        KeyGui:Destroy()
                        keyResult = true
                    end)
                end)
            else
                keyAttempts = keyAttempts + 1
                local errorMsg = msg or "Invalid key"
                StatusLabel.TextColor3 = C3(255, 80, 80)
                ValidateBtn.Text = Localization:Get("ValidateKey")
                if errorMsg == "KEY_EXPIRED" then
                    StatusLabel.Text = "Key expired - get a new one"
                    KeyNotify("Key has expired!", C3(255, 180, 50), 3)
                elseif errorMsg == "HWID_BANNED" then
                    StatusLabel.Text = "Hardware banned"
                    KeyNotify("Hardware banned!", C3(255, 0, 0), 4)
                    task.delay(2, function() Player:Kick("Hardware banned") end)
                elseif errorMsg == "KEY_INVALIDATED" then
                    StatusLabel.Text = "Key was disabled"
                    KeyNotify("Key manually disabled!", C3(255, 80, 80), 3)
                elseif errorMsg == "ALREADY_USED" then
                    StatusLabel.Text = "Key already used"
                    KeyNotify("One-time key already redeemed!", C3(255, 80, 80), 3)
                elseif errorMsg == "HWID_MISMATCH" then
                    StatusLabel.Text = "HWID limit reached"
                    KeyNotify("Max devices for this key!", C3(255, 150, 50), 3)
                elseif errorMsg == "SERVICE_NOT_FOUND" or errorMsg == "SERVICE_MISMATCH" then
                    StatusLabel.Text = "Service error"
                    KeyNotify("Service configuration error!", C3(255, 150, 50), 3)
                elseif errorMsg == "PREMIUM_REQUIRED" then
                    StatusLabel.Text = "Premium required"
                    KeyNotify("Premium key required!", C3(255, 200, 50), 3)
                elseif errorMsg == "KEY_INVALID" then
                    StatusLabel.Text = "Key not found"
                    KeyNotify("Key not found in system!", C3(255, 80, 80), 3)
                elseif type(errorMsg) == "string" and errorMsg:match("^http") then
                    StatusLabel.Text = "Server error"
                    KeyNotify("Server error - try again", C3(255, 80, 80), 3)
                else
                    StatusLabel.Text = tostring(errorMsg)
                    KeyNotify(tostring(errorMsg), C3(255, 80, 80), 3)
                end
                if keyAttempts >= maxKeyAttempts then
                    ValidateBtn.Text = "Too many attempts"
                    StatusLabel.Text = "Maximum attempts reached"
                    StatusLabel.TextColor3 = C3(255, 0, 0)
                    KeyNotify("Too many failed attempts!", C3(255, 0, 0), 4)
                end
                TweenService:Create(KeyCard, TweenInfo.new(0.05), {Position = UDim2.new(0.5, 6, 0.5, 0)}):Play()
                task.delay(0.05, function()
                    TweenService:Create(KeyCard, TweenInfo.new(0.05), {Position = UDim2.new(0.5, -6, 0.5, 0)}):Play()
                    task.delay(0.05, function()
