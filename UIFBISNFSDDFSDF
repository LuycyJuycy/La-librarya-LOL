            Circle.Image = GetIcon("CircleClick")
            Circle.ImageColor3 = C3(80, 80, 80)
            Circle.ImageTransparency = 0.8999999761581421
            Circle.BackgroundColor3 = C3(255, 255, 255)
            Circle.BackgroundTransparency = 1
            Circle.ZIndex = 10
            Circle.Name = "Circle"
            Circle.Parent = Button

            local NewX = X - Button.AbsolutePosition.X
            local NewY = Y - Button.AbsolutePosition.Y
            Circle.Position = UDim2.new(0, NewX, 0, NewY)

            local Size = math.max(Button.AbsoluteSize.X, Button.AbsoluteSize.Y) * 1.5

            local Time = 0.5
            local clickTweenInfo = TweenInfo.new(Time, Enum.EasingStyle.Quad, Enum.EasingDirection.Out)

            local Tween =
                TweenService:Create(
                Circle,
                clickTweenInfo,
                {
                    Size = UDim2.new(0, Size, 0, Size),
                    Position = UDim2.new(0.5, -Size / 2, 0.5, -Size / 2)
                }
            )

            Tween:Play()

            Tween.Completed:Connect(
                function()
                    for i = 1, 10 do
                        Circle.ImageTransparency = Circle.ImageTransparency + 0.01
                        task.wait(Time / 10)
                    end
                    Circle:Destroy()
                end
            )
        end
    )
end

local function AddHover(frame, normalTrans, hoverTrans)
    normalTrans = normalTrans or frame.BackgroundTransparency
    hoverTrans = hoverTrans or math.max(0, normalTrans - 0.08)
    local hoverIn = TweenInfo.new(0.12, Enum.EasingStyle.Quad, Enum.EasingDirection.Out)
    local hoverOut = TweenInfo.new(0.22, Enum.EasingStyle.Quad, Enum.EasingDirection.Out)
    local isHovered = false
    frame.MouseEnter:Connect(function()
        isHovered = true
        TweenService:Create(frame, hoverIn, {BackgroundTransparency = hoverTrans}):Play()
        if not frame:FindFirstChild("UIScale") then
            local s = Instance.new("UIScale")
            s.Parent = frame
        end
        local sc = frame:FindFirstChild("UIScale")
        if sc then
            TweenService:Create(sc, hoverIn, {Scale = 1.008}):Play()
        end
    end)
    frame.MouseLeave:Connect(function()
        isHovered = false
        TweenService:Create(frame, hoverOut, {BackgroundTransparency = normalTrans}):Play()
        local sc = frame:FindFirstChild("UIScale")
        if sc then
            TweenService:Create(sc, hoverOut, {Scale = 1}):Play()
        end
    end)
    return function(newNormal)
        normalTrans = newNormal
        hoverTrans = math.max(0, newNormal - 0.08)
        if not isHovered then
            frame.BackgroundTransparency = normalTrans
        end
    end
end

