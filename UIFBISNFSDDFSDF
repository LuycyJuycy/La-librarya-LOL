        local JunkieSDK
        local loadOk = pcall(function()
            JunkieSDK = loadstring(game:HttpGet("https://jnkie.com/sdk/library.lua"))()
        end)
        if not loadOk or not JunkieSDK then
            return {
                Verify = function() return false, "ERROR" end,
                Copy = function() return "" end
            }
        end
        JunkieSDK.service = tostring(service)
        JunkieSDK.identifier = tostring(identifier)
        JunkieSDK.provider = tostring(provider or "Mixed")
        local function validateKey(key)
            local ok, result = pcall(function()
                return JunkieSDK.check_key(key)
            end)
            if ok and result then
                if result.valid or result.success then
                    return true, "Key validated!"
                end
                return false, result.error or "Invalid key"
            end
            return false, "ERROR"
        end
