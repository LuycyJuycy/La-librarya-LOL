                TweenService:Create(LayersTab, tweenInfo, {Position = UDim2.new(0, 9, 0, 50), Size = UDim2.new(0, TabWidth, 1, -59)}):Play()
                if Layers then
                    TweenService:Create(Layers, tweenInfo, {
