            TweenService:Create(nf, TweenInfo.new(0.3, Enum.EasingStyle.Quart, Enum.EasingDirection.In), {Position = UDim2.new(0.5, 0, 0, -50)}):Play()
            task.delay(0.3, function()
                for i, v in ipairs(notifList) do
                    if v == nf then table.remove(notifList, i) break end
                end
                nf:Destroy()
                for i, v in ipairs(notifList) do
                    TweenService:Create(v, TweenInfo.new(0.2, Enum.EasingStyle.Quad), {Position = UDim2.new(0.5, 0, 0, 12 + (i - 1) * 48)}):Play()
                end
            end)
