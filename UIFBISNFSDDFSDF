                        Position = UDim2.new(0, 10, 0, 6),
                        Size = UDim2.new(1, -20, 0, 16),
                        Name = "VideoTitle"
                    },
                    VideoContainer
                )

                if VideoId ~= "" then
                    local videoFrame = Custom:Create(
                        "VideoFrame",
                        {
                            Video = "rbxassetid://" .. tostring(VideoId),
                            BackgroundColor3 = C3(0, 0, 0),
                            BackgroundTransparency = 0,
                            BorderSizePixel = 0,
                            Position = UDim2.new(0, 5, 0, 26),
                            Size = UDim2.new(1, -10, 0, Height),
                            Looped = Looped,
                            Playing = AutoPlay,
                            Volume = 0,
                            Name = "VideoPlayer"
                        },
                        VideoContainer
                    )
                    Custom:Create("UICorner", {CornerRadius = UDim.new(0, 4)}, videoFrame)

                    function Funcs_Video:Play() videoFrame.Playing = true end
                    function Funcs_Video:Pause() videoFrame.Playing = false end
                    function Funcs_Video:SetVideo(newId) videoFrame.Video = "rbxassetid://" .. tostring(newId) end
                    function Funcs_Video:SetLooped(val) videoFrame.Looped = val end

                elseif GifURL ~= "" then
                    local gifLabel = Custom:Create(
                        "ImageLabel",
                        {
                            Image = GifURL,
                            BackgroundColor3 = C3(0, 0, 0),
                            BackgroundTransparency = 0,
                            BorderSizePixel = 0,
                            Position = UDim2.new(0, 5, 0, 26),
                            Size = UDim2.new(1, -10, 0, Height),
                            ScaleType = Enum.ScaleType.Fit,
                            Name = "GifDisplay"
                        },
                        VideoContainer
                    )
                    Custom:Create("UICorner", {CornerRadius = UDim.new(0, 4)}, gifLabel)

                    function Funcs_Video:SetGif(url) gifLabel.Image = url end

                    if GifURL:match("spritesheet") or Config.SpriteSheet then
                        local cols = Config.Columns or 8
                        local rows = Config.Rows or 8
                        local fps = Config.FPS or 15
                        local totalFrames = Config.TotalFrames or (cols * rows)

                        gifLabel.ScaleType = Enum.ScaleType.Crop

                        local currentFrame = 0
                        local playing = AutoPlay

                        task.spawn(function()
                            while gifLabel and gifLabel.Parent do
                                if playing then
                                    local col = currentFrame % cols
                                    local row = math.floor(currentFrame / cols)
                                    gifLabel.ImageRectOffset = V2(col * (1 / cols) * gifLabel.AbsoluteSize.X, row * (1 / rows) * gifLabel.AbsoluteSize.Y)
                                    gifLabel.ImageRectSize = V2(gifLabel.AbsoluteSize.X / cols, gifLabel.AbsoluteSize.Y / rows)
                                    currentFrame = (currentFrame + 1) % totalFrames
                                end
                                task.wait(1 / fps)
                            end
                        end)

                        function Funcs_Video:Play() playing = true end
                        function Funcs_Video:Pause() playing = false end
                    end
                end

                function Funcs_Video:SetHeight(h)
                    VideoContainer.Size = UDim2.new(1, 0, 0, h + 30)
                    local player = VideoContainer:FindFirstChild("VideoPlayer") or VideoContainer:FindFirstChild("GifDisplay")
                    if player then player.Size = UDim2.new(1, -10, 0, h) end
                end

                ItemCount = ItemCount + 1
                return Funcs_Video
            end

            function Item:AddTextSizeSelector(Config)
                local Title = Config[1] or Config.Title or "Text Size"
                local Content = Config[2] or Config.Content or "Adjust text size"
                local Default = Config[3] or Config.Default or 0
                local Callback = Config[4] or Config.Callback or function()
                    end

                if not Funcs.AllTextElements then
                    Funcs.AllTextElements = {}
                end

                if not Funcs.OriginalTextSizes then
                    Funcs.OriginalTextSizes = {}
                end

                local function RegisterAllTextElements(parent)
                    for _, descendant in ipairs(parent:GetDescendants()) do
                        if descendant:IsA("TextLabel") or descendant:IsA("TextButton") or descendant:IsA("TextBox") then
                            if not table.find(Funcs.AllTextElements, descendant) then
                                table.insert(Funcs.AllTextElements, descendant)
                                Funcs.OriginalTextSizes[descendant] = descendant.TextSize
                            end
                        end
                    end
                end

                RegisterAllTextElements(Funcs.Main)

                local function ApplyTextSizeOffset(offset)
                    RegisterAllTextElements(Funcs.Main)

                    for _, textElement in ipairs(Funcs.AllTextElements) do
                        if textElement and textElement.Parent then
                            local originalSize = Funcs.OriginalTextSizes[textElement] or textElement.TextSize
                            local newSize = math.max(8, math.min(36, originalSize + offset))
                            textElement.TextSize = newSize
                        end
                    end
                end

                if Default ~= 0 then
                    ApplyTextSizeOffset(Default)
                end

                local TextSizeSlider =
                    Item:AddSlider(
                    {
                        Title = Title,
                        Content = Content,
                        Increment = 1,
                        Min = -6,
                        Max = 12,
                        Default = Default,
                        Callback = function(value)
                            ApplyTextSizeOffset(value)
                            Callback(value)
                        end
                    }
                )

                return TextSizeSlider
            end

            ItemCount = ItemCount + 1
            return Item
        end

        CountTab = CountTab + 1
        return DirectItem
    end

