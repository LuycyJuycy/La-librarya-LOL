    local SearchOpen = false

PerformSearch = function()
        local ok, err = pcall(function()
            local query = string.lower(SearchInput.Text)
            if not LayersPageLayout then return end
            local currentPage = LayersPageLayout.CurrentPage
            if not currentPage then return end

            for _, child in pairs(currentPage:GetChildren()) do
                if child:IsA("Frame") then
                    local elementType = child.Name
                    local filterActive = ActiveFilters[elementType]
                    if filterActive == nil then filterActive = true end

                    if query == "" then
                        child.Visible = true
                    else
                        local titleLabel = child:FindFirstChild("ButtonTitle")
                            or child:FindFirstChild("ToggleTitle")
                            or child:FindFirstChild("SliderTitle")
                            or child:FindFirstChild("InputTitle")
                            or child:FindFirstChild("DropdownTitle")
                            or child:FindFirstChild("ParagraphTitle")
                            or child:FindFirstChild("SeperatorTitle")
                            or child:FindFirstChild("SectionTitle")

                        local titleText = ""
                        if titleLabel then titleText = string.lower(titleLabel.Text) end

                        local matchesQuery = string.find(titleText, query, 1, true) ~= nil
                        child.Visible = matchesQuery and filterActive
                    end

                    if child.Name == "DirectSection" then
                        for _, subChild in pairs(child:GetChildren()) do
                            if subChild:IsA("Frame") then
                                local subType = subChild.Name
                                local subFilterActive = ActiveFilters[subType]
                                if subFilterActive == nil then subFilterActive = true end

                                if query == "" then
                                    subChild.Visible = true
                                else
                                    local subTitle = subChild:FindFirstChild("ButtonTitle")
                                        or subChild:FindFirstChild("ToggleTitle")
                                        or subChild:FindFirstChild("SliderTitle")
                                        or subChild:FindFirstChild("InputTitle")
                                        or subChild:FindFirstChild("ParagraphTitle")
                                        or subChild:FindFirstChild("SeperatorTitle")

                                    local subText = ""
                                    if subTitle then subText = string.lower(subTitle.Text) end

                                    subChild.Visible = string.find(subText, query, 1, true) ~= nil and subFilterActive
                                end
                            end
                        end
                    end
                end

                if child.Name == "Section" then
                    local sectionAdd = child:FindFirstChild("SectionAdd")
                    if sectionAdd and query ~= "" then
                        local anyVisible = false
                        for _, sItem in pairs(sectionAdd:GetChildren()) do
                            if sItem:IsA("Frame") then
                                local sType = sItem.Name
                                local sFilterActive = ActiveFilters[sType]
                                if sFilterActive == nil then sFilterActive = true end

                                local sTitle = sItem:FindFirstChild("ButtonTitle")
                                    or sItem:FindFirstChild("ToggleTitle")
                                    or sItem:FindFirstChild("SliderTitle")
                                    or sItem:FindFirstChild("InputTitle")
                                    or sItem:FindFirstChild("DropdownTitle")
                                    or sItem:FindFirstChild("ParagraphTitle")
                                    or sItem:FindFirstChild("SeperatorTitle")

                                local sText = ""
                                if sTitle then sText = string.lower(sTitle.Text) end

                                local vis = string.find(sText, query, 1, true) ~= nil and sFilterActive
                                sItem.Visible = vis
                                if vis then anyVisible = true end
                            end
                        end
                        child.Visible = anyVisible
                    elseif query == "" then
                        child.Visible = true
                        if sectionAdd then
                            for _, sItem in pairs(sectionAdd:GetChildren()) do
                                if sItem:IsA("Frame") then
                                    sItem.Visible = true
                                end
                            end
                        end
                    end
                end
            end
        end)
    end

