    local function formatTime12Hour()
        local currentTime = os.date("*t")
        local hour = currentTime.hour
        local min = currentTime.min
        local ampm = "AM"
        
        if hour >= 12 then
            ampm = "PM"
            if hour > 12 then
                hour = hour - 12
            end
        end
        if hour == 0 then
            hour = 12
        end
        
        return string.format("%d:%02d %s", hour, min, ampm)
    end

