    function Localization:DetectLanguage()
        local locale = LocaleId or "en-us"
        local langCode = locale:sub(1, 2):lower()
        if self.Strings[langCode] then
            self.CurrentLanguage = langCode
        else
            self.CurrentLanguage = "en"
        end
        return self.CurrentLanguage
    end

    function Localization:SetLanguage(langCode)
        langCode = langCode:lower()
        if self.Strings[langCode] then
            self.CurrentLanguage = langCode
        end
    end

    function Localization:Get(key)
        local langStrings = self.Strings[self.CurrentLanguage]
        if langStrings and langStrings[key] then
            return langStrings[key]
        end
        local fallback = self.Strings["en"]
        if fallback and fallback[key] then
            return fallback[key]
        end
        return key
    end

    function Localization:AddLanguage(langCode, strings)
        self.Strings[langCode:lower()] = strings
    end

    Localization:DetectLanguage()
end

